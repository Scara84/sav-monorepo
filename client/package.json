{
  "name": "@sav-app/client",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "start": "node server.js",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:update": "vitest -u",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "lint:business": "eslint api/_lib/business/ --ext .ts --max-warnings 0",
    "format": "prettier --write src/",
    "typecheck": "vue-tsc --noEmit",
    "prepare": "cd .. && husky client/.husky"
  },
  "lint-staged": {
    "*.{js,jsx,cjs,mjs,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx,json,yml,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@azure/msal-node": "^3.6.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/supabase-js": "^2.103.3",
    "@vercel/functions": "^3.4.4",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.3.4",
    "nodemailer": "^8.0.5",
    "pinia": "^3.0.4",
    "radix-vue": "^1.9.17",
    "vue": "^3.5.32",
    "vue-router": "^4.1.6",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/user-event": "^14.5.1",
    "@testing-library/vue": "^7.0.0",
    "@types/eslint": "^9.6.1",
    "@types/nodemailer": "^8.0.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitejs/plugin-vue-jsx": "^3.0.1",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.9.1",
    "@vue/vue3-jest": "^29.2.6",
    "autoprefixer": "^10.4.13",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^9.14.1",
    "happy-dom": "^17.6.3",
    "husky": "^9.1.7",
    "jsdom": "^22.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.21",
    "prettier": "^3.0.0",
    "supabase": "^2.92.1",
    "tailwindcss": "^3.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^5.2.0",
    "vitest": "^1.6.0",
    "vue-tsc": "^3.2.6"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended",
      "plugin:prettier/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2020
    },
    "rules": {},
    "overrides": [
      {
        "files": [
          "*.vue"
        ],
        "parser": "vue-eslint-parser",
        "parserOptions": {
          "parser": "@typescript-eslint/parser",
          "ecmaVersion": 2022,
          "sourceType": "module"
        },
        "env": {
          "browser": true,
          "es2022": true
        }
      },
      {
        "files": [
          "*.ts",
          "*.tsx"
        ],
        "parser": "@typescript-eslint/parser",
        "parserOptions": {
          "ecmaVersion": 2022,
          "sourceType": "module"
        },
        "env": {
          "browser": true,
          "node": true,
          "es2022": true
        },
        "rules": {
          "no-unused-vars": "off",
          "no-undef": "off"
        }
      },
      {
        "files": [
          "src/App.vue",
          "src/components/layout/Header.vue",
          "src/views/Home.vue",
          "src/features/sav/views/Home.vue"
        ],
        "rules": {
          "vue/multi-word-component-names": "off",
          "vue/no-reserved-component-names": "off"
        }
      },
      {
        "files": [
          "api/_lib/business/**/*.ts"
        ],
        "excludedFiles": [
          "api/_lib/business/**/*.test.ts",
          "api/_lib/business/**/*.spec.ts"
        ],
        "rules": {
          "no-restricted-imports": [
            "error",
            {
              "paths": [
                {
                  "name": "fs",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "fs/promises",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "node:fs",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "node:fs/promises",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "node:child_process",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "node:http",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "node:https",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "node:net",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "node:dns",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "axios",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "undici",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "node-fetch",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "nodemailer",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "ioredis",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "redis",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "pg",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "pg-promise",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "name": "drizzle-orm",
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                }
              ],
              "patterns": [
                {
                  "group": [
                    "@supabase/*"
                  ],
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "group": [
                    "@microsoft/*"
                  ],
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "group": [
                    "@azure/*"
                  ],
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                },
                {
                  "group": [
                    "@prisma/*"
                  ],
                  "message": "Modules _lib/business doivent rester purs (no-io)."
                }
              ]
            }
          ]
        }
      },
      {
        "files": [
          "src/features/back-office/composables/useSavLinePreview.ts"
        ],
        "rules": {
          "no-restricted-globals": [
            "error",
            {
              "name": "fetch",
              "message": "Composable preview doit rester pur (no-io). Utiliser uniquement api/_lib/business/*."
            },
            {
              "name": "XMLHttpRequest",
              "message": "Composable preview doit rester pur (no-io)."
            },
            {
              "name": "WebSocket",
              "message": "Composable preview doit rester pur (no-io)."
            }
          ],
          "no-restricted-imports": [
            "error",
            {
              "paths": [
                {
                  "name": "axios",
                  "message": "Composable preview doit rester pur (no-io)."
                }
              ],
              "patterns": [
                {
                  "group": [
                    "@supabase/*"
                  ],
                  "message": "Composable preview doit rester pur (no-io)."
                },
                {
                  "group": [
                    "**/clients/**",
                    "**/_lib/clients/**"
                  ],
                  "message": "Composable preview doit rester pur (no-io). Aucun client IO autorise."
                }
              ]
            }
          ]
        }
      }
    ]
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 100,
    "trailingComma": "es5"
  }
}
