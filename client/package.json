{
  "name": "@sav-app/client",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "start": "node server.js",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:update": "vitest -u",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "typecheck": "vue-tsc --noEmit",
    "prepare": "cd .. && husky client/.husky"
  },
  "lint-staged": {
    "*.{js,jsx,cjs,mjs,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx,json,yml,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@azure/msal-node": "^3.6.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/supabase-js": "^2.103.3",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.3.4",
    "nodemailer": "^8.0.5",
    "pinia": "^3.0.4",
    "radix-vue": "^1.9.17",
    "vue": "^3.5.32",
    "vue-router": "^4.1.6",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/user-event": "^14.5.1",
    "@testing-library/vue": "^7.0.0",
    "@types/nodemailer": "^8.0.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitejs/plugin-vue-jsx": "^3.0.1",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.9.1",
    "@vue/vue3-jest": "^29.2.6",
    "autoprefixer": "^10.4.13",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^9.14.1",
    "happy-dom": "^17.6.3",
    "husky": "^9.1.7",
    "jsdom": "^22.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.21",
    "prettier": "^3.0.0",
    "supabase": "^2.92.1",
    "tailwindcss": "^3.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^5.2.0",
    "vitest": "^1.6.0",
    "vue-tsc": "^3.2.6"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended",
      "plugin:prettier/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2020
    },
    "rules": {},
    "overrides": [
      {
        "files": [
          "*.vue"
        ],
        "parser": "vue-eslint-parser",
        "parserOptions": {
          "parser": "@typescript-eslint/parser",
          "ecmaVersion": 2022,
          "sourceType": "module"
        },
        "env": {
          "browser": true,
          "es2022": true
        }
      },
      {
        "files": [
          "*.ts",
          "*.tsx"
        ],
        "parser": "@typescript-eslint/parser",
        "parserOptions": {
          "ecmaVersion": 2022,
          "sourceType": "module"
        },
        "env": {
          "browser": true,
          "node": true,
          "es2022": true
        },
        "rules": {
          "no-unused-vars": "off",
          "no-undef": "off"
        }
      }
    ]
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 100,
    "trailingComma": "es5"
  }
}
