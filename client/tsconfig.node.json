{
  "compilerOptions": {
    "composite": true,
    "allowJs": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "vite.config.js",
    "vitest.config.js",
    "playwright.config.js",
    "postcss.config.js",
    "tailwind.config.js"
  ]
}
