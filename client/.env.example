# =========================
# Epic 1 — héritage
# =========================

# Authentification API (REQUIS)
# Envoyée en header X-API-Key aux routes Vercel serverless /api/*
# Doit correspondre à la valeur de API_KEY côté Vercel (variables Preview/Prod)
# Générer avec: openssl rand -base64 32
VITE_API_KEY=your_secure_api_key_here_minimum_32_characters

# Mode maintenance (0 = désactivé, 1 = activé)
VITE_MAINTENANCE_MODE=0

# Jeton pour bypass du mode maintenance (optionnel — renommé par h-18 D4, ancien nom VITE_MAINTENANCE_BYPASS_TOKEN cassait PATTERN-H18-A)
VITE_MAINTENANCE_BYPASS=your_secret_bypass_token

# =========================
# Phase 2 — Supabase
# =========================

# URL publique du projet Supabase (exposée au front, sans risque)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Clé publishable (nouvelle gen, recommandée). Exposée au front, OK.
# Dashboard → Project Settings → API → "publishable" key
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxx

# Clé service_role (PRIVÉE — jamais préfixée VITE_, jamais exposée au client)
# Utilisée uniquement par les fonctions serverless /api/admin/**
# Dashboard → Project Settings → API → "service_role" key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Connection string Postgres pour les migrations (supabase CLI)
# Dashboard → Project Settings → Database → Connection string → URI
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# =========================
# Phase 2 — Microsoft 365 service principal (Graph M2M)
# =========================
# Story 5.8 — l'auth utilisateur opérateur n'utilise plus MSAL (passé en magic link).
# Ces credentials restent utilisés en mode client_credentials pour l'accès machine-to-
# machine à Graph API (OneDrive Story 2.4, Pennylane futur).

# Préfixe primaire MICROSOFT_*, fallback AZURE_* pour compat Story 1.4.
MICROSOFT_TENANT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_CLIENT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_CLIENT_SECRET=

# =========================
# Phase 2 — Magic link (Story 1.5 adhérent + Story 5.8 opérateur)
# =========================

# JWT secret HS256 pour signer les magic links (256 bits / 32 bytes random)
# Générer: openssl rand -base64 32
MAGIC_LINK_SECRET=

# Secret cookie session (256 bits)
SESSION_COOKIE_SECRET=

# Story 5.8 — TTL session opérateur en heures (défaut 8h, journée de travail).
# Bornes acceptées : 1 ≤ N ≤ 168 (1 semaine). Hors bornes → fallback 8h + warn log.
OPERATOR_SESSION_TTL_HOURS=8

# =========================
# Phase 2 — SMTP Infomaniak (Story 1.5)
# =========================

SMTP_HOST=mail.infomaniak.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@fruitstock.fr
SMTP_PASSWORD=
SMTP_FROM="SAV Fruitstock <noreply@fruitstock.fr>"

# =========================
# Phase 2 — Divers
# =========================

# URL de base de l'app (utilisée dans les magic links + emails)
APP_BASE_URL=http://localhost:3000


# =========================
# Story 5.7 — Pennylane API + SMTP SAV (cutover Make)
# =========================

# Pennylane API v2 (auth Bearer côté serveur — secret).
# Génération : Pennylane UI → Settings → API → scope `customer_invoices:readonly`.
# À provisionner via `vercel env add PENNYLANE_API_KEY production` au moment du cutover.
PENNYLANE_API_KEY=
PENNYLANE_API_BASE_URL=https://app.pennylane.com/api/external/v2

# Compte SMTP dédié emails SAV `sav@fruitstock.eu` (différent de `noreply@`
# Story 1.5/5.8 conservé pour magic-links). Décision PM 2026-04-28 : 2 comptes
# Infomaniak distincts → SPF/DKIM alignés sur `@fruitstock.eu` pour les
# emails sortants depuis `sav@`, séparation propre noreply ≠ opérationnel.
SMTP_SAV_HOST=mail.infomaniak.com
SMTP_SAV_PORT=465
SMTP_SAV_SECURE=true
SMTP_SAV_USER=sav@fruitstock.eu
SMTP_SAV_PASSWORD=
SMTP_SAV_FROM="SAV Fruitstock <sav@fruitstock.eu>"

# Destinataire de l'email interne post-INSERT SAV (configurable pour staging
# où on peut pointer sur `dev+sav@fruitstock.eu`). Défaut : sav@fruitstock.eu.
SMTP_NOTIFY_INTERNAL=sav@fruitstock.eu

# TTL capture-token JWT en secondes (Story 5.7 AC #9). Défaut 300 (5 min) :
# laisse le temps à l'adhérent de finaliser le formulaire SAV après upload
# OneDrive. Bornes acceptées : 60 ≤ N ≤ 3600.
SAV_SUBMIT_TOKEN_TTL_SEC=300

# =========================
# Story 7-6 — RGPD admin (export signé HMAC + anonymisation adhérent)
# =========================

# D-1 — secret HMAC-SHA256 utilisé pour signer le JSON exporté
# (`POST /api/admin/members/:id/rgpd-export`). ≥ 32 bytes obligatoire.
# Si absent ou < 32 bytes → 500 RGPD_SECRET_NOT_CONFIGURED (fail-fast).
# Générer : openssl rand -base64 48
# Vérifier l'export plus tard : RGPD_EXPORT_HMAC_SECRET=<valeur> node scripts/verify-rgpd-export.mjs export.json
RGPD_EXPORT_HMAC_SECRET=

# D-10 — salt utilisé par la RPC PG `admin_anonymize_member` pour calculer
# `hash8 = substr(sha256(member_id || salt), 1, 8)` (déterministe). Injecté
# dans la TX via GUC `app.rgpd_anonymize_salt` (`SET app.rgpd_anonymize_salt
# = '<value>';` au niveau session/role Supabase). Si absent côté DB → la RPC
# raise `RGPD_SALT_NOT_CONFIGURED` → handler 500.
# Générer : openssl rand -base64 32
RGPD_ANONYMIZE_SALT=

# ===== Serveur — auth & CORS =====

# auth gate /api/cron/* (Bearer header) — generate: openssl rand -base64 32
CRON_SECRET=

# HMAC server-side counterpart de VITE_API_KEY (même valeur)
API_KEY=

# CSV des origins CORS autorisés (ex: https://sav.fruitstock.fr,https://preview.vercel.app)
ALLOWED_ORIGINS=

# ===== OneDrive (Microsoft Graph) =====

# ID du drive OneDrive partagé (Story 2.4)
MICROSOFT_DRIVE_ID=

# Chemin racine dans le drive (ex: /Documents/SAV)
MICROSOFT_DRIVE_PATH=

# ===== Toggles opérationnels =====

# 1 = ignore le guard Friday-only sur weekly-recap.ts
WEEKLY_RECAP_BYPASS_FRIDAY=0

# 1 = expose /api/healthcheck verbose output
HEALTH_DEBUG=0

# ===== Phase 2 — URLs serveur =====

# variant non-VITE pour les imports serveur Supabase
SUPABASE_URL=https://<project-ref>.supabase.co

# même valeur que APP_BASE_URL, exposée bundle SPA
VITE_APP_BASE_URL=http://localhost:3000
