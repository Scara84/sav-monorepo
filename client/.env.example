# =========================
# Epic 1 — héritage
# =========================

# URL du webhook pour récupérer les données de facture
VITE_WEBHOOK_URL=https://hook.eu2.make.com/your_webhook_id

# URL du webhook pour envoyer les données SAV
VITE_WEBHOOK_URL_DATA_SAV=https://hook.eu2.make.com/your_webhook_id

# Authentification API (REQUIS)
# Envoyée en header X-API-Key aux routes Vercel serverless /api/*
# Doit correspondre à la valeur de API_KEY côté Vercel (variables Preview/Prod)
# Générer avec: openssl rand -base64 32
VITE_API_KEY=your_secure_api_key_here_minimum_32_characters

# Mode maintenance (0 = désactivé, 1 = activé)
VITE_MAINTENANCE_MODE=0

# Jeton secret pour bypass du mode maintenance (optionnel)
VITE_MAINTENANCE_BYPASS_TOKEN=your_secret_bypass_token

# =========================
# Phase 2 — Supabase
# =========================

# URL publique du projet Supabase (exposée au front, sans risque)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Clé publishable (nouvelle gen, recommandée). Exposée au front, OK.
# Dashboard → Project Settings → API → "publishable" key
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxx

# Clé service_role (PRIVÉE — jamais préfixée VITE_, jamais exposée au client)
# Utilisée uniquement par les fonctions serverless /api/admin/**
# Dashboard → Project Settings → API → "service_role" key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Connection string Postgres pour les migrations (supabase CLI)
# Dashboard → Project Settings → Database → Connection string → URI
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# =========================
# Phase 2 — Auth MSAL (Story 1.4)
# =========================

AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Optionnel si PKCE pur côté client ; requis pour confidential client flow
AZURE_CLIENT_SECRET=

# =========================
# Phase 2 — Magic link (Story 1.5)
# =========================

# JWT secret HS256 pour signer les magic links (256 bits / 32 bytes random)
# Générer: openssl rand -base64 32
MAGIC_LINK_SECRET=

# Secret cookie session (256 bits)
SESSION_COOKIE_SECRET=

# =========================
# Phase 2 — SMTP Infomaniak (Story 1.5)
# =========================

SMTP_HOST=mail.infomaniak.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@fruitstock.fr
SMTP_PASSWORD=
SMTP_FROM="SAV Fruitstock <noreply@fruitstock.fr>"

# =========================
# Phase 2 — Divers
# =========================

# URL de base de l'app (utilisée dans les magic links + emails)
APP_BASE_URL=http://localhost:3000

# HMAC secret pour vérifier les webhooks Make.com entrants (Story 2.2)
MAKE_WEBHOOK_SECRET=
