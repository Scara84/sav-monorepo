      { "header": "DESIGNATION (ESP)", "source": "products.name_es", "transform": "direct" },
      { "header": "ORIGEN", "source": "products.origin", "transform": "direct" },
      {
        "header": "INFO",
        "source": null,
        "transform": "empty_v1",
        "note": "Colonne legacy vide en V1"
      },
      {
        "header": "TAXE",
        "source": "products.vat_rate_bp",
        "transform": "divide_100",
        "note": "vat_rate_bp / 100"
      },
      { "header": "UNITÉ (FR)", "source": "products.default_unit", "transform": "direct" },
      {
        "header": "10kg (FR)",
        "source": null,
        "transform": "empty_v1",
        "note": "Prix tranche — vide V1"
      },
      {
        "header": "30kg (FR)2",
        "source": null,
        "transform": "empty_v1",
        "note": "Prix tranche — vide V1"
      },
      {
        "header": "60kg (FR)",
        "source": null,
        "transform": "empty_v1",
        "note": "Prix tranche — vide V1"
      },
      {
        "header": "5kg Min",
        "source": null,
        "transform": "empty_v1",
        "note": "Prix tranche — vide V1"
      },
      {
        "header": "CAGETTE (5kg)",
        "source": null,
        "transform": "empty_v1",
        "note": "Prix tranche — vide V1"
      },
      {
        "header": "PRIX (ESP)",
        "source": null,
        "transform": "empty_v1",
        "note": "Prix export — vide V1"
      },
      {
        "header": "10kg (ESP)",
        "source": null,
        "transform": "empty_v1",
        "note": "Prix tranche — vide V1"
      },
      {
        "header": "30kg (ESP)",
        "source": null,
        "transform": "empty_v1",
        "note": "Prix tranche — vide V1"
      },
      {
        "header": "60kg (ESP)",
        "source": null,
        "transform": "empty_v1",
        "note": "Prix tranche — vide V1"
      },
      {
        "header": "Récup code",
        "source": null,
        "transform": "empty_v1",
        "note": "Colonne macro legacy — vide V1"
      }
    ]
  },
  "groups": {
    "sheet_name": "GROUPES",
    "mapping_kind": "legacy",
