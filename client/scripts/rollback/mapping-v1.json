{
  "members": {
    "sheet_name": "CLIENTS",
    "mapping_kind": "legacy",
    "columns": [
      { "header": "ID", "source": "members.id", "transform": "direct" },
      { "header": "PRENOM NOM", "source": "first_name || ' ' || last_name", "transform": "concat" },
      { "header": "EMAIL", "source": "members.email", "transform": "direct" },
      { "header": "GROUPE", "source": "groups.name", "transform": "lookup:group_id→groups.name" },
      { "header": "DEPT", "source": "groups.dept", "transform": "lookup:group_id→groups.dept" },
      {
        "header": "KEY",
        "source": "members.pennylane_customer_id",
        "transform": "direct",
        "note": "pennylane_customer_id = legacy KEY column"
      }
    ]
  },
  "products": {
    "sheet_name": "BDD",
    "mapping_kind": "legacy",
    "columns": [
      { "header": "CODE", "source": "products.code", "transform": "direct" },
